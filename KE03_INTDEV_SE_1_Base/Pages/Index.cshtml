@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<!-- Order plaatsen knop hier -->
<div class="mb-3">
    <a class="btn btn-primary" asp-page="/Order_Plaatsen">Plaats een nieuwe order</a>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Klant</th>
            <th>Aantal Orders</th>
        </tr>
    </thead>
    @foreach (var c in Model.Customers)
    {        
        <tr>
            <td>@Html.DisplayName(c.Name)</td>
            <td>@Html.DisplayName(c.Orders.Count.ToString())</td>           
        </tr>
    }
</table>